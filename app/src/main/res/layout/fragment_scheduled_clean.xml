<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/activity_horizontal_margin">

        <!-- Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/schedule_name"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etScheduleName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Enable Switch -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target"
            android:text="@string/schedule_enabled"
            android:layout_marginBottom="@dimen/item_spacing" />

        <!-- Status -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvScheduleStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginBottom="@dimen/section_spacing" />

        <!-- Recurrence Section -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/schedule_recurrence"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="@dimen/item_spacing" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/schedule_frequency"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spinnerFrequency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDayOfWeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/schedule_day_of_week"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spinnerDayOfWeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDayOfMonth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/schedule_day_of_month"
            android:visibility="gone"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spinnerDayOfMonth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Time -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTime"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target"
            android:text="@string/schedule_time"
            android:layout_marginBottom="@dimen/section_spacing" />

        <!-- Delete Threshold -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/schedule_threshold"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="@dimen/item_spacing" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/section_spacing"
            android:hint="@string/schedule_delete_older_than"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spinnerThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Message Types -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_message_types"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="@dimen/item_spacing" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbSchedSms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target"
            android:checked="true"
            android:text="@string/sms_checkbox" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbSchedMmsMedia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target"
            android:checked="true"
            android:text="@string/mms_media_checkbox" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbSchedMmsGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target"
            android:checked="true"
            android:text="@string/mms_group_checkbox" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbSchedRcs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target"
            android:layout_marginBottom="@dimen/section_spacing"
            android:checked="false"
            android:text="@string/rcs_checkbox" />

        <!-- Batch Settings -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_batch_settings"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="@dimen/item_spacing" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/batch_size"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSchedBatchSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="1000"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/batch_size_mms_media"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSchedBatchSizeMmsMedia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="100"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/batch_size_mms_group"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSchedBatchSizeMmsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="500"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/delete_chunk_size"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSchedChunkSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="50"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/section_spacing"
            android:hint="@string/batch_delay"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSchedDelay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="100"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Conditions -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbRequiresCharging"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target"
            android:layout_marginBottom="@dimen/section_spacing"
            android:checked="true"
            android:text="@string/schedule_requires_charging" />

        <!-- Save / Delete / Cancel Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/activity_vertical_margin">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveSchedule"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:minHeight="@dimen/min_touch_target"
                android:text="@string/schedule_save" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteSchedule"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:minHeight="@dimen/min_touch_target"
                android:text="@string/delete" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelSchedule"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target"
                android:text="@string/confirm_delete_negative" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
