<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/outerScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:descendantFocusability="beforeDescendants"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/activity_horizontal_margin">

            <!-- Exclusions Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageExclusions"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target"
                android:layout_marginBottom="@dimen/item_spacing"
                android:text="@string/manage_exclusions" />

            <!-- Storage Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStorage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/section_spacing"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/storage_status"
                        android:textAppearance="?attr/textAppearanceTitleSmall" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvStorageStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/loading"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:layout_marginTop="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRefreshStorage"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:minHeight="@dimen/min_touch_target"
                        android:text="@string/refresh" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Date Range Section -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_date_range"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="@dimen/item_spacing" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/item_spacing">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartDate"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="@dimen/min_touch_target"
                    android:text="@string/start_date" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearStartDate"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/min_touch_target"
                    android:text="@string/clear"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/section_spacing">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEndDate"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="@dimen/min_touch_target"
                    android:text="@string/end_date" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearEndDate"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/min_touch_target"
                    android:text="@string/clear"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Message Types Section -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_message_types"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="@dimen/item_spacing" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target"
                android:checked="true"
                android:text="@string/sms_checkbox" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbMmsMedia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target"
                android:checked="true"
                android:text="@string/mms_media_checkbox" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbMmsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target"
                android:checked="true"
                android:text="@string/mms_group_checkbox" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbRcs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target"
                android:layout_marginBottom="@dimen/section_spacing"
                android:checked="false"
                android:text="@string/rcs_checkbox" />

            <!-- Batch Settings Section -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_batch_settings"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="@dimen/item_spacing" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/item_spacing"
                android:hint="@string/batch_size"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBatchSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="@string/batch_size_default"
                    android:minHeight="@dimen/min_touch_target" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbPerTypeBatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target"
                android:text="@string/per_type_batch_size" />

            <LinearLayout
                android:id="@+id/layoutPerTypeBatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/item_spacing"
                    android:hint="@string/batch_size_mms_media"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBatchSizeMmsMedia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="100"
                        android:minHeight="@dimen/min_touch_target" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/item_spacing"
                    android:hint="@string/batch_size_mms_group"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBatchSizeMmsGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="500"
                        android:minHeight="@dimen/min_touch_target" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/item_spacing"
                android:hint="@string/delete_chunk_size"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDeleteChunkSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="@string/delete_chunk_size_default"
                    android:minHeight="@dimen/min_touch_target" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/section_spacing"
                android:hint="@string/batch_delay"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBatchDelay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="@string/batch_delay_default"
                    android:minHeight="@dimen/min_touch_target" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Delete Order -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/delete_order"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:layout_marginBottom="@dimen/item_spacing" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleDeleteOrder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/section_spacing"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@id/btnOldestFirst">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOldestFirst"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="@dimen/min_touch_target"
                    android:text="@string/oldest_first" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNewestFirst"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="@dimen/min_touch_target"
                    android:text="@string/newest_first" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Debug -->
            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbDebugLogging"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target"
                android:checked="false"
                android:text="@string/debug_logging" />

            <!-- Auto-tune -->
            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbAutoTune"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target"
                android:layout_marginBottom="@dimen/section_spacing"
                android:checked="false"
                android:text="@string/auto_tune" />

            <!-- Actions Section -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_actions"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="@dimen/item_spacing" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/item_spacing">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDryRun"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:minHeight="@dimen/min_touch_target"
                    android:text="@string/btn_dry_run" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRun"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:minHeight="@dimen/min_touch_target"
                    android:text="@string/btn_run" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:minHeight="@dimen/min_touch_target"
                android:text="@string/btn_stop"
                android:layout_marginBottom="@dimen/item_spacing" />

            <!-- Progress -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvProgressLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:layout_marginBottom="@dimen/item_spacing"
                android:visibility="gone" />

            <!-- Log Output Section -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_log"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="@dimen/item_spacing" />

            <ScrollView
                android:id="@+id/scrollLog"
                android:layout_width="match_parent"
                android:layout_height="@dimen/log_area_height"
                android:background="@color/log_background"
                android:padding="8dp"
                android:layout_marginBottom="@dimen/activity_vertical_margin">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:fontFamily="monospace"
                    android:textAppearance="?attr/textAppearanceBodySmall" />
            </ScrollView>

        </LinearLayout>
    </ScrollView>

    <!-- Floating Default SMS Warning -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDefaultSms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="@dimen/activity_horizontal_margin"
        android:elevation="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorErrorContainer"
        app:cardCornerRadius="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_sms_required"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSetDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="@dimen/min_touch_target"
                android:text="@string/btn_set_default" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
