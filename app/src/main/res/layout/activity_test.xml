<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/activity_horizontal_margin">

        <!-- Title -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/test_activity_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:layout_marginBottom="@dimen/section_spacing" />

        <!-- Message Counts -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/sms_count"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSmsCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="100"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/mms_media_count"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMmsMediaCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="20"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/mms_group_count"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMmsGroupCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="10"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Date Range -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_date_range"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="@dimen/item_spacing"
            android:layout_marginTop="@dimen/item_spacing" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestStartDate"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target"
            android:text="@string/start_date"
            android:layout_marginBottom="@dimen/item_spacing" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestEndDate"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target"
            android:text="@string/end_date"
            android:layout_marginBottom="@dimen/item_spacing" />

        <!-- Conversations -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:hint="@string/conversation_count"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etConversationCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="5"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/section_spacing"
            android:hint="@string/group_conversation_count"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGroupConversationCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="3"
                android:minHeight="@dimen/min_touch_target" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Generate / Cancel Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/item_spacing">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:minHeight="@dimen/min_touch_target"
                android:text="@string/btn_generate" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:minHeight="@dimen/min_touch_target"
                android:text="@string/btn_stop" />
        </LinearLayout>

        <!-- Progress -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/testProgressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/item_spacing"
            android:indeterminate="true"
            android:visibility="gone" />

        <!-- Log Output -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_log"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="@dimen/item_spacing" />

        <ScrollView
            android:id="@+id/scrollTestLog"
            android:layout_width="match_parent"
            android:layout_height="@dimen/log_area_height"
            android:background="@color/log_background"
            android:padding="8dp"
            android:layout_marginBottom="@dimen/section_spacing">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvTestLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:fontFamily="monospace"
                android:textAppearance="?attr/textAppearanceBodySmall" />
        </ScrollView>

        <!-- Back Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target"
            android:text="@string/btn_back"
            android:layout_marginBottom="@dimen/activity_vertical_margin" />

    </LinearLayout>
</ScrollView>
